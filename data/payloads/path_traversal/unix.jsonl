{"text": "....\\\\....\\\\....\\\\etc\\\\passwd", "technique": "path_traversal", "databases": ["any"], "contexts": ["url_param"], "waf_bypasses": ["generic"], "severity_boost": 0.70, "explanation": "Backslash variant. Some path handlers on Windows or misconfigured systems accept backslashes. Double backslash for JSON escaping."}
